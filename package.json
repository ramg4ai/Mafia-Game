{
  "name": "mafia-game",
  "version": "1.0.0",
  "description": "Multiplayer Mafia party game",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testMatch": [
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "gameLogic.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ]
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
